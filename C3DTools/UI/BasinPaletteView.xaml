<UserControl x:Class="C3DTools.UI.BasinPaletteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:C3DTools.UI"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="320"
             Background="White">
    <UserControl.Resources>
        <!-- Value Converters -->
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <!-- Styles -->
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Selected Basin Section -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Selected Basin" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" Padding="8" Background="#F9F9F9"
                    Visibility="{Binding SelectedBasin, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock>
                        <Run Text="Layer: " FontWeight="SemiBold"/>
                        <Run Text="{Binding SelectedBasin.Layer, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Handle: " FontWeight="SemiBold"/>
                        <Run Text="{Binding SelectedBasin.ObjectId.Handle, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Edit Basin Attributes -->
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="Basin ID:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding NewBasinId, UpdateSourceTrigger=PropertyChanged}" 
                                 Padding="4" Margin="0,0,0,8"/>

                        <TextBlock Text="Boundary:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding BoundaryOptions}" 
                                  SelectedItem="{Binding SelectedBoundary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,8"/>

                        <TextBlock Text="Development:" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding DevelopmentOptions}" 
                                  SelectedItem="{Binding SelectedDevelopment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,8"/>

                        <Button Content="{Binding TagButtonText}" Command="{Binding TagBasinCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Select a basin polyline to see details here."
                       Foreground="Gray" FontStyle="Italic"
                       Visibility="{Binding SelectedBasin, Converter={StaticResource InverseNullToVisibilityConverter}}"/>
        </StackPanel>

        <!-- Tagged Basins Section -->
        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <DockPanel Margin="0,0,0,8">
                <Button Content="↻" DockPanel.Dock="Right" Width="28" Height="28" 
                        Command="{Binding RefreshCommand}" ToolTip="Refresh basin list"
                        Margin="8,0,0,0" Padding="0"/>
                <TextBlock Text="Tagged Basins" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Column Headers -->
            <Grid Margin="4,0,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.6*" MinWidth="35"/>
                    <ColumnDefinition Width="0.8*" MinWidth="70"/>
                    <ColumnDefinition Width="0.9*" MinWidth="85"/>
                    <ColumnDefinition Width="1.5*" MinWidth="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="ID" FontWeight="SemiBold" FontSize="11" Foreground="#666666" Grid.Column="0" Padding="4,2"/>
                <TextBlock Text="Boundary" FontWeight="SemiBold" FontSize="11" Foreground="#666666" Grid.Column="1" Padding="4,2"/>
                <TextBlock Text="Development" FontWeight="SemiBold" FontSize="11" Foreground="#666666" Grid.Column="2" Padding="4,2"/>
                <TextBlock Text="Layer" FontWeight="SemiBold" FontSize="11" Foreground="#666666" Grid.Column="3" Padding="4,2"/>
            </Grid>

            <ListBox ItemsSource="{Binding TaggedBasins}" 
                     SelectedItem="{Binding SelectedTaggedBasin}"
                     MinHeight="120" MaxHeight="300"
                     BorderThickness="1" BorderBrush="#CCCCCC"
                     Padding="0,0,0,4">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding DataContext.SelectBasinItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Stretch"
                                Padding="0"
                                Margin="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Background" Value="#BBDEFB"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.6*" MinWidth="35"/>
                                    <ColumnDefinition Width="0.8*" MinWidth="70"/>
                                    <ColumnDefinition Width="0.9*" MinWidth="85"/>
                                    <ColumnDefinition Width="1.5*" MinWidth="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding BasinId}" Grid.Column="0" VerticalAlignment="Center" Padding="4,4"/>
                                <TextBlock Text="{Binding Boundary}" Grid.Column="1" VerticalAlignment="Center" Padding="4,4" Foreground="#555555"/>
                                <TextBlock Text="{Binding Development}" Grid.Column="2" VerticalAlignment="Center" Padding="4,4" Foreground="#555555"/>
                                <TextBlock Text="{Binding Layer}" Grid.Column="3" VerticalAlignment="Center" Padding="4,4" Foreground="#555555"/>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="{Binding TaggedBasins.Count, StringFormat='Count: {0}'}" 
                       Margin="0,4,0,0" Foreground="Gray" FontSize="11"/>
        </StackPanel>

        <Separator Grid.Row="2" Margin="0,12"/>

        <!-- Untagged Basins Section -->
        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <DockPanel Margin="0,0,0,8">
                <Button Content="↻" DockPanel.Dock="Right" Width="28" Height="28" 
                        Command="{Binding RefreshCommand}" ToolTip="Refresh basin list"
                        Margin="8,0,0,0" Padding="0"/>
                <TextBlock Text="Untagged Basins" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
            </DockPanel>

            <!-- Layer Filter -->
            <DockPanel Margin="0,0,0,8">
                <TextBlock Text="Filter by Layer:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding AvailableLayers}" 
                          SelectedItem="{Binding SelectedLayer}"
                          MinWidth="150"/>
            </DockPanel>

            <ListBox ItemsSource="{Binding UntaggedBasins}" 
                     SelectedItem="{Binding SelectedUntaggedBasin}"
                     MinHeight="120" MaxHeight="300"
                     BorderThickness="1" BorderBrush="#CCCCCC"
                     Padding="0,0,0,4">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding DisplayText}" 
                                Command="{Binding DataContext.SelectBasinItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Left"
                                Padding="8,4"
                                Margin="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Foreground="#666666">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter Property="Background" Value="#BBDEFB"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Text="{Binding UntaggedBasins.Count, StringFormat='Count: {0}'}" 
                       Margin="0,4,0,0" Foreground="Gray" FontSize="11"/>
        </StackPanel>

        <!-- Info Section -->
        <StackPanel Grid.Row="4" Margin="0,16,0,0">
            <TextBlock TextWrapping="Wrap" FontSize="10" Foreground="Gray">
                <Run Text="Tip: Use TAGBASIN, GETBASIN, LABELBASIN, and SPLITBASINS commands for additional operations."/>
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
